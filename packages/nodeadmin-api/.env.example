# ============ 数据库配置 ============
# 数据库类型：sqlite | mysql
DB_TYPE=sqlite

# SQLite 配置（DB_TYPE=sqlite 时生效）
DB_PATH=./data/nodeadmin.db

# MySQL 配置（DB_TYPE=mysql 时生效）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=nodeadmin

# 自动同步表结构（true=启用，false=关闭，默认 true）
DB_SYNCHRONIZE=true

# ============ 服务配置 ============
# 服务端口
PORT=3000

# JWT（过期时间为秒，例：3600=1小时，604800=7天）
JWT_ACCESS_SECRET=please-change-me-to-a-random-string
JWT_ACCESS_EXPIRES_IN=604800

# CORS 跨域白名单（逗号分隔）
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# 上传目录（头像等静态资源存放路径）
UPLOAD_DIR=./uploads

# 请求体大小限制（默认 10mb）
BODY_LIMIT=10mb
