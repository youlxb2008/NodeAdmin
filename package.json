{
  "name": "nodeadmin",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev:api": "pnpm --filter @nodeadmin/api start:dev",
    "dev:web": "pnpm --filter @nodeadmin/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r --parallel exec eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,vue,js,json,md,css}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0"
  }
}
